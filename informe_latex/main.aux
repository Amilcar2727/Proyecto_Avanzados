\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Escalabilidad con $n$ para $m=2n$ (disperso). Líneas punteadas grises: referencias teóricas $O(n\log n)$ y $O(n^2)$ normalizadas al punto $n=500$ de Dijkstra. El crecimiento empírico de Dijkstra ($4.86\times $ de $n=500$ a $n=5\,000$) es sublineal respecto al factor teórico $O(n\log n) \approx 13.7\times $, lo que refleja la eficiencia de la caché para $m$ pequeño.}}{9}{figure.6}\protected@file@percent }
\newlabel{fig:g4}{{6}{9}{Escalabilidad con $n$ para $m=2n$ (disperso). Líneas punteadas grises: referencias teóricas $O(n\log n)$ y $O(n^2)$ normalizadas al punto $n=500$ de Dijkstra. El crecimiento empírico de Dijkstra ($4.86\times $ de $n=500$ a $n=5\,000$) es sublineal respecto al factor teórico $O(n\log n) \approx 13.7\times $, lo que refleja la eficiencia de la caché para $m$ pequeño}{figure.6}{}}
